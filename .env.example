# Copier ce fichier en .env.local et remplir les valeurs

# Mot de passe pour la famille (accès lecture)
VITE_FAMILY_PASSWORD=recettes2024

# Mot de passe admin (accès écriture — vous seulement)
VITE_ADMIN_PASSWORD=admin2024

# GitHub — pour sauvegarder les recettes
VITE_GITHUB_OWNER=votre-username-github
VITE_GITHUB_REPO=mon-livre-de-recettes
VITE_GITHUB_BRANCH=main
VITE_GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx
